# LLM configuration
OPENAI_API_KEY=your_deepseek_or_openai_key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# SMTP test sender configuration
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=your_sender@163.com
SMTP_AUTH_CODE=your_163_authorization_code
TEST_TO_EMAIL=your_receiver@qq.com

